# ==============================================================
# Telegram bot token. 從 @BotFather 取得。
# 步驟：開 Telegram → 搜尋 @BotFather → /newbot → 取 token
# ==============================================================
TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# ==============================================================
# 允許指揮這個 bot 的 Telegram chat_id（逗號分隔）。
# 取得自己的 chat_id：先把 token 填好啟動 bot，傳任意訊息給 bot，
# 看 bot console log，會印出你的 chat_id。然後填回這裡重啟。
# 沒設定 = 拒絕所有人（避免被陌生人指揮家裡電腦）
# ==============================================================
ALLOWED_CHAT_IDS=

# ==============================================================
# 預設 working directory。bot 啟動時用這個。
# 用戶可以透過 /project <name> 切換。
# ==============================================================
DEFAULT_PROJECT=default

# ==============================================================
# 專案清單，格式：name=path,name=path
# 範例：default=C:/Web/OnlinePrint-Production,bot=C:/claude/remotetools
# ==============================================================
PROJECTS=default=C:/claude/remotetools

# ==============================================================
# Claude permission mode（手機遠端建議 bypassPermissions，否則新檔案/工具會被擋）
# - acceptEdits: 只自動允許檔案編輯，bash 仍會 prompt → bot 會卡死（不推薦）
# - auto: 依 ~/.claude/settings.json 的 allow/deny 規則決定；沒在 allow 內的工具會被擋
#   （沒人能在手機端按 /permissions Always Allow 補規則就會卡）
# - bypassPermissions: 完全跳過權限檢查（推薦給手機遠端；失去 deny 黑名單保護）
# - default: 一般模式 → bot 會卡死（不要用）
# ==============================================================
PERMISSION_MODE=bypassPermissions

# ==============================================================
# 每次 Claude 呼叫的 timeout（秒）。預設 600 = 10 分鐘
# ==============================================================
CLAUDE_TIMEOUT_SECONDS=600

# ==============================================================
# Claude 模型。空白 = 用 settings.json 預設
# 範例：opus / sonnet / haiku / claude-opus-4-7
# ==============================================================
CLAUDE_MODEL=

# ==============================================================
# 每次呼叫預算上限（USD）。0 = 不設限
# ==============================================================
MAX_BUDGET_USD=0

# ==============================================================
# 每天每個用戶最多幾則訊息（0 = 不限）。
# 用來保護 Max 訂閱配額：bot 自動化比手動快很多，
# 若不小心連發 / 被打洗版，可能 30 分鐘就燒完 5 小時額度。
# 預設 100 則對個人用算寬鬆。
# ==============================================================
DAILY_MESSAGE_LIMIT=100

# ==============================================================
# 每分鐘速率限制（0 = 不限）。
# 滾動 60 秒視窗，超過就回「太頻繁了，等 X 秒」。
# 預設 6 則/分（每 10 秒一則）= 防手抖連按。
# ==============================================================
RATE_LIMIT_PER_MINUTE=6
