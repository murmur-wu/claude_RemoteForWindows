# ==============================================================
# Discord bot token. 取得步驟：
# 1. 開 https://discord.com/developers/applications → New Application
# 2. 左側 Bot → Reset Token → 複製貼到下方
#    （注意：不是 Application ID、不是 Public Key、是 Bot Token）
# 3. 同一頁往下捲：Privileged Gateway Intents
#    → 必須開啟 MESSAGE CONTENT INTENT（不開 bot 收不到訊息內容）
# 4. OAuth2 → URL Generator
#    Scopes: 勾 bot
#    Bot Permissions: 至少勾 Send Messages, Read Message History
#    用產生的 URL 把 bot 邀進你的 server，或私訊 bot 都可以。
# ==============================================================
DISCORD_BOT_TOKEN=

# ==============================================================
# 允許指揮這個 bot 的 Discord user_id（逗號分隔，純數字）。
# 取得自己的 user_id：
#   Discord → Settings → Advanced → 開啟 Developer Mode
#   對自己頭像/名字右鍵 → Copy User ID
# 或先把 token 填好啟動 bot，傳訊息給 bot，看 console log 印的 user_id。
# 沒設定 = 拒絕所有人（避免被陌生人指揮家裡電腦）
# ==============================================================
ALLOWED_USER_IDS=

# ==============================================================
# 預設 working directory。bot 啟動時用這個。
# 用戶可以透過 !project <name> 切換。
# ==============================================================
DEFAULT_PROJECT=default

# ==============================================================
# 專案清單，格式：name=path,name=path
# 範例：default=C:/Web/OnlinePrint-Production,bot=C:/claude/remotetools
# ==============================================================
PROJECTS=default=C:/claude/remotetools

# ==============================================================
# 指令前綴（預設 !）。送 "!status" 之類觸發指令；
# 不以前綴開頭的訊息一律送給 Claude。
# ==============================================================
COMMAND_PREFIX=!

# ==============================================================
# Claude permission mode（預設 auto，搭配 ~/.claude/settings.json 的 deny 黑名單）
# - acceptEdits: 只自動允許檔案編輯，bash 仍會 prompt → bot 會卡死（不推薦）
# - auto: 自動允許所有操作（推薦，但 settings.json 要設好 deny 規則擋危險指令）
# - bypassPermissions: 完全跳過權限檢查（最危險，連 deny 都不會生效）
# - default: 一般模式 → bot 會卡死（不要用）
# ==============================================================
PERMISSION_MODE=auto

# ==============================================================
# 每次 Claude 呼叫的 timeout（秒）。預設 600 = 10 分鐘
# ==============================================================
CLAUDE_TIMEOUT_SECONDS=600

# ==============================================================
# Claude 模型。空白 = 用 settings.json 預設
# 範例：opus / sonnet / haiku / claude-opus-4-7
# ==============================================================
CLAUDE_MODEL=

# ==============================================================
# 每次呼叫預算上限（USD）。0 = 不設限
# ==============================================================
MAX_BUDGET_USD=0

# ==============================================================
# 每天每個用戶最多幾則訊息（0 = 不限）。
# 用來保護 Max 訂閱配額：bot 自動化比手動快很多，
# 若不小心連發 / 被打洗版，可能 30 分鐘就燒完 5 小時額度。
# ==============================================================
DAILY_MESSAGE_LIMIT=100

# ==============================================================
# 每分鐘速率限制（0 = 不限）。
# 滾動 60 秒視窗，超過就回「太頻繁了，等 X 秒」。
# ==============================================================
RATE_LIMIT_PER_MINUTE=6
